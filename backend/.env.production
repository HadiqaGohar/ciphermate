# Production Environment Configuration for CipherMate Backend
# This file contains template values - actual secrets should be stored in Google Cloud Secret Manager

# Application Configuration
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8080
WORKERS=1

# Database Configuration (stored in Secret Manager)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# Redis Configuration (if using Redis Cloud or Google Memorystore)
# REDIS_URL=redis://user:password@host:6379

# Auth0 Configuration (stored in Secret Manager)
# AUTH0_DOMAIN=your-domain.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# AUTH0_AUDIENCE=https://your-domain.auth0.com/api/v2/

# AI API Configuration (stored in Secret Manager)
# GEMINI_API_KEY=your-gemini-api-key

# OAuth Client Configuration (stored in Secret Manager)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret

# Security Configuration
ALLOWED_ORIGINS=["https://your-frontend-domain.vercel.app"]
JWT_ALGORITHM=RS256
SESSION_TIMEOUT=3600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring and Logging
ENABLE_METRICS=true
ENABLE_AUDIT_LOGGING=true
LOG_FORMAT=json

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=10