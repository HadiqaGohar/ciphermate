# CipherMate Production Environment Variables
# Copy this file to .env.prod and fill in your actual production values

# Database Configuration (Supabase)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_DB=ciphermate_prod
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-database-password@postgres:5432/ciphermate_prod

# Redis Configuration

REDIS_PASSWORD=your-secure-redis-password

# Auth0 Configuration
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=https://your-domain.auth0.com/api/v2/
AUTH0_ISSUER_BASE_URL=https://your-domain.auth0.com
AUTH0_SECRET=your-32-character-random-string-for-session-encryption

# AI API Configuration
GEMINI_API_KEY=your-gemini-api-key

# OAuth Client Configuration
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
SLACK_CLIENT_ID=your-slack-oauth-client-id
SLACK_CLIENT_SECRET=your-slack-oauth-client-secret

# Google Cloud Configuration (for deployment)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1